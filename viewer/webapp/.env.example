# For local development only (see DEPLOYMENT.md's "Local development"
# section). The real Kubernetes deployment gets these values from a
# kubectl-created Secret instead — see DEPLOYMENT.md step 3.
#
# Copy this file to .env (same folder) and fill in real values.
# .env is gitignored — never commit real secrets here.

# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=

# From the existing Camunda Azure AD app registration (Entra ID > App registrations):
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
# Certificates & secrets > New client secret — copy the VALUE, not the secret ID.
AZURE_CLIENT_SECRET=
# Must exactly match a Redirect URI registered on the app registration, e.g.:
# https://dashboard.es-sandbox.com/daily-brief/auth/callback
AZURE_REDIRECT_URI=

# Leave unset to allow any Camunda tenant user to sign in. To restrict to a
# specific Azure AD group later, set this to a comma-separated list of group
# object IDs and enable group claims on the app registration's token config.
ALLOWED_GROUPS=

# No UPLOAD_TOKENS here anymore — each person's API token is assigned
# automatically the first time they sign in (see db.py's
# get_or_create_user), and retrieved via GET /api/token once signed in.
# For local testing of the skill-facing endpoints, sign in once through
# the dev server, hit /api/token in your browser, and use that value.

# For local dev, point at a local Postgres (see DEPLOYMENT.md's "Local
# development" section for a quick local setup). In the real deployment
# this is built from postgres-credentials via Kubernetes env var
# interpolation instead — see k8s/deployment.yaml.
DATABASE_URL=postgresql://dailybrief:localpassword@localhost:5432/dailybrief
