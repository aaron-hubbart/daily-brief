# Add this location block to the existing nginx server block for
# dashboard.es-sandbox.com — don't create a new server block, since this
# is meant to live alongside whatever's already being served there.
#
# Adjust /daily-brief/ to whatever path you'd rather use; it just has to
# match AZURE_REDIRECT_URI's path and the app registration's Redirect URI.

location /daily-brief/ {
    proxy_pass http://127.0.0.1:8000/;
    proxy_set_header Host $host;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Prefix /daily-brief;

    # OAuth redirects and long-ish MSAL token exchanges — generous but bounded.
    proxy_connect_timeout 10s;
    proxy_read_timeout 60s;
}

# If TLS termination happens at this nginx (not a separate load balancer),
# the app's SESSION_COOKIE_SECURE=True setting requires the request nginx
# forwards actually be over HTTPS end-to-end from the browser's perspective —
# the X-Forwarded-Proto header above is how the app knows that's true even
# though the proxy_pass hop itself is plain HTTP to 127.0.0.1.
